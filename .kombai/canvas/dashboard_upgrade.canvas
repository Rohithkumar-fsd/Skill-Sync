"text\" placeholder=\"QUICK ADD TASK...\" class=\"flex-1 border border-black px-6 py-5 text-xs font-black uppercase tracking-widest outline-none focus:bg-black focus:text-white transition-all\" data-kid=\"121\">\n                <button class=\"h-[60px] w-[60px] shrink-0 bg-black text-white flex items-center justify-center btn-snappy tooltip-trigger\" data-tooltip=\"Create Task\" data-kid=\"122\">\n                  <i class=\"ti ti-plus text-3xl\" data-kid=\"123\"></i>\n                </button>\n              </div>\n              <div class=\"space-y-4\" data-kid=\"124\">\n                <div class=\"group flex items-center gap-6 border-2 border-black p-6 hover:bg-black hover:text-white transition-all\" data-kid=\"125\">\n                  <div class=\"h-8 w-8 border-2 border-black group-hover:border-white shrink-0 flex items-center justify-center\" data-kid=\"126\">\n                    <i class=\"ti ti-check text-xl opacity-0 group-hover:opacity-100\" data-kid=\"127\"></i>\n                  </div>\n                  <div class=\"flex-1\" data-kid=\"128\">\n                    <p class=\"text-xl font-black uppercase tracking-tighter\" data-kid=\"129\">Morning Yoga Flow</p>\n                  </div>\n                </div>\n                <div class=\"group flex items-center gap-6 border-2 border-black p-6 hover:bg-black hover:text-white transition-all\" data-kid=\"139\">\n                  <div class=\"h-8 w-8 border-2 border-black group-hover:border-white shrink-0\" data-kid=\"140\"></div>\n                  <div class=\"flex-1\" data-kid=\"141\">\n                    <p class=\"text-xl font-black uppercase tracking-tighter\" data-kid=\"142\">DSA: Advanced Graph Patterns</p>\n                  </div>\n                </div>\n              </div>\n            </section>\n          </div>\n\n          <div class=\"col-span-12 lg:col-span-4 space-y-10\" data-kid=\"177\">\n            <section class=\"border-2 border-black p-10 bg-white text-center gsap-reveal\" id=\"mastery-section\" data-kid=\"178\">\n              <h2 class=\"text-2xl font-black font-[var(--k-font-family-heading)] uppercase tracking-tighter mb-12\" data-kid=\"179\">Overall Mastery</h2>\n              <div class=\"relative mx-auto h-64 w-64 mb-12\" data-kid=\"180\">\n                <svg class=\"h-full w-full rotate-[-90deg]\" viewBox=\"0 0 100 100\" data-kid=\"101\">\n                  <circle cx=\"50\" cy=\"50\" r=\"45\" fill=\"none\" stroke=\"#E5E5E5\" stroke-width=\"8\" data-kid=\"107\"></circle>\n                  <circle id=\"mastery-ring\" cx=\"50\" cy=\"50\" r=\"45\" fill=\"none\" stroke=\"#000\" stroke-width=\"8\" stroke-dasharray=\"283\" stroke-dashoffset=\"283\" stroke-linecap=\"butt\" data-kid=\"108\"></circle>\n                </svg>\n                <div class=\"absolute inset-0 flex flex-col items-center justify-center\" data-kid=\"184\">\n                  <p class=\"text-6xl font-black font-[var(--k-font-family-heading)] tracking-tighter\" id=\"mastery-percent\" data-kid=\"185\">0%</p>\n                </div>\n              </div>\n            </section>\n\n            <section class=\"bg-black p-10 text-white relative min-h-[300px] flex flex-col justify-between overflow-hidden gsap-reveal\" data-kid=\"203\">\n              <div class=\"relative z-10\" data-kid=\"206\">\n                <h3 class=\"text-4xl font-black font-[var(--k-font-family-heading)] uppercase tracking-tighter italic leading-none mb-4\" data-kid=\"209\">AI Skill Gap Analyzer</h3>\n              </div>\n              <button class=\"relative z-10 w-full bg-white text-black py-5 text-xs font-black uppercase tracking-[0.3em] btn-snappy border-none\" data-kid=\"211\">\n                Start Analysis <i class=\"ti ti-arrow-right ml-2\" data-kid=\"119\"></i>\n              </button>\n            </section>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"h-24 lg:hidden\" data-kid=\"230\"></div>\n    </main>\n  </div>\n\n  \n  <nav class=\"lg:hidden fixed bottom-0 left-0 right-0 h-20 bg-white border-t border-black flex items-center justify-around px-4 z-[100] shadow-[0_-4px_10px_rgba(0,0,0,0.1)]\" data-kid=\"231\">\n    <a href=\"#\" class=\"flex flex-col items-center gap-1 text-white bg-black p-3\" data-kid=\"232\">\n      <i class=\"ti ti-layout-dashboard text-xl\" data-kid=\"233\"></i>\n    </a>\n    <a href=\"#\" class=\"flex flex-col items-center gap-1 text-black/40 hover:text-black\" data-kid=\"234\">\n      <i class=\"ti ti-certificate text-xl\" data-kid=\"235\"></i>\n    </a>\n    <a href=\"#\" class=\"flex flex-col items-center gap-1 text-black/40 hover:text-black\" data-kid=\"236\">\n      <i class=\"ti ti-list-check text-xl\" data-kid=\"237\"></i>\n    </a>\n    <a href=\"#\" class=\"flex flex-col items-center gap-1 text-black/40 hover:text-black\" data-kid=\"238\">\n      <i class=\"ti ti-target text-xl\" data-kid=\"239\"></i>\n    </a>\n    <button onclick=\"toggleMobileSidebar()\" class=\"flex flex-col items-center gap-1 text-black/40 hover:text-black\" aria-label=\"Open Mobile Drawer\" data-kid=\"130\">\n      <i class=\"ti ti-menu-2 text-xl\" data-kid=\"131\"></i>\n    </button>\n  </nav>\n</div>\n\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js\" data-kid=\"132\"></script>\n<script data-kid=\"133\">\n  function toggleSidebar() {\n    const sidebar = document.getElementById('sidebar');\n    const toggleIcon = document.getElementById('toggle-icon');\n    const isCollapsed = sidebar.classList.toggle('sidebar-collapsed');\n    \n    if (isCollapsed) {\n      toggleIcon.classList.replace('ti-layout-sidebar-left-collapse', 'ti-layout-sidebar-left-expand');\n    } else {\n      toggleIcon.classList.replace('ti-layout-sidebar-left-expand', 'ti-layout-sidebar-left-collapse');\n    }\n  }\n\n  function toggleMobileSidebar() {\n    const sidebar = document.getElementById('sidebar');\n    const overlay = document.getElementById('sidebar-overlay');\n    sidebar.classList.toggle('mobile-open');\n    overlay.classList.toggle('active');\n  }\n\n  window.addEventListener('DOMContentLoaded', () => {\n    // 1. STAGGERED ENTRANCE\n    const timeline = gsap.timeline();\n    \n    timeline.to(\".gsap-reveal\", {\n      opacity: 1,\n      y: 0,\n      duration: 0.6,\n      stagger: 0.1,\n      ease: \"power3.out\",\n      clearProps: \"transform\"\n    });\n\n    // 2. PROGRESS ANIMATION (Overall Mastery Radial)\n    const masteryObj = { value: 0 };\n    const masteryRing = document.getElementById('mastery-ring');\n    const masteryText = document.getElementById('mastery-percent');\n    const totalLength = 283; \n\n    gsap.to(masteryObj, {\n      value: 68,\n      duration: 2,\n      delay: 0.5,\n      ease: \"power4.out\",\n      onUpdate: () => {\n        const offset = totalLength - (masteryObj.value / 100) * totalLength;\n        masteryRing.style.strokeDashoffset = offset;\n        masteryText.textContent = Math.round(masteryObj.value) + \"%\";\n      }\n    });\n\n    gsap.set(\".gsap-reveal\", { y: 20, opacity: 0 });\n  });\n</script>",
